# クラウド DB（例: RDS）
DATABASE_URL=postgres://user:password@your-host.region.rds.amazonaws.com:5432/dbname?sslmode=require

# AWS IAM（コピーして .env にリネームし、値を入力）
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=ap-northeast-1
# AWS_SESSION_TOKEN=  # 一時認証情報を使用する場合のみ
